            },
            "url": {
              "raw": "http://localhost:8082/api/v1/audit/events",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8082",
              "path": [
                "api",
                "v1",
                "audit",
                "events"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Audit - Get Event by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8082/api/v1/audit/events/event-id",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8082",
              "path": [
                "api",
                "v1",
                "audit",
                "events",
                "event-id"
              ]
            }
          },
          "response": []
        }
      ]
